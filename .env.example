MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=bet99
MYSQL_USER=bet99_user
MYSQL_PASSWORD=bet99_pass

# Exposed MySQL port on host (change if 3306 is already in use)
MYSQL_PORT=3306

# Exposed app port on host (change if 8080 is already in use)
APP_PORT=8080

# Only set this when the JSP client and the API server run on different machines.
# Leave blank (or omit) when both run on the same host.
# API_BASE_URL=http://<api-server-ip>:8080
